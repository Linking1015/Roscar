<launch>
  <arg name="can_device" default="can0" />

  <node pkg="socketcan_bridge" type="socketcan_bridge_node" name="socketcan_bridge" output="screen">
    <param name="can_device" value="$(arg can_device)" />
  </node>

  <node pkg="ars408_ros" type="ars408_node.py" name="ars408_node" output="screen" />
  <node pkg="ars408_ros" type="tf_publisher.py" name="sensor_tf_publisher" output="screen" />
</launch>

<launch>
  <!-- ===================== -->
  <!-- 1. 启动机器人底层 -->
  <!-- ===================== -->
  <include file="$(find start_roscar)/launch/start_roscar.launch" />

  <!-- ===================== -->
  <!-- 3. 地图服务器 -->
  <!-- ===================== -->
  <arg name="map_file" default="$(find start_roscar)/map/roscar_map.yaml"/>
  <node pkg="map_server" type="map_server" name="map_server_roscar" args="$(arg map_file)" output="screen"/>

  <!-- ===================== -->
  <!-- 4. AMCL 定位 -->
  <!-- ===================== -->
  <include file="$(find start_roscar)/launch/include/amcl.launch" />

  <!-- ===================== -->
  <!-- 5. move_base + Navigation -->
  <!-- ===================== -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <!-- 全局参数 -->
    <rosparam command="load" file="$(find start_roscar)/param/move_base_params.yaml"/>
    <!-- 全局 costmap -->
    <rosparam command="load" file="$(find start_roscar)/param/global_costmap_params.yaml"/>
    <!-- 局部 costmap -->
    <rosparam command="load" file="$(find start_roscar)/param/local_costmap_params.yaml"/>
    <!-- costmap 通用参数（必须指定 ns，否则 obstacle_layer/observation_sources 加载不到正确位置） -->
    <rosparam command="load" file="$(find start_roscar)/param/costmap_common_params.yaml" ns="local_costmap"/>
    <rosparam command="load" file="$(find start_roscar)/param/costmap_common_params.yaml" ns="global_costmap"/>
    <!-- Global Planner 参数 -->
    <rosparam command="load" file="$(find start_roscar)/param/base_global_planner_param.yaml"/>
    <!-- TEB Local Planner 参数 -->
    <rosparam command="load" file="$(find start_roscar)/param/teb_local_planner_params.yaml"/>
    <!-- TF 容忍时间 -->
    <param name="transform_tolerance" value="1.0"/>
    <param name="use_sim_time" value="false"/>
  </node>

  <!-- 6. 红绿灯检测 (YOLOv8 + LiDAR 融合) -->
  <node name="fusion_node" pkg="traffic_light_yolo" type="fusion_yolo_lidar.py" output="screen">
    <env name="LD_PRELOAD" value="/usr/lib/aarch64-linux-gnu/libgomp.so.1" />
  </node>

  <!-- 7.激光雷达行人检测避障 -->
  <include file="$(find radar_obstacle)/launch/person_detection.launch" />

</launch>

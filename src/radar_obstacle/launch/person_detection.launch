<launch>

  <include file="$(find ars408_ros)/launch/ars408_radar.launch" />

  <!-- =========================== -->
  <!-- 纯雷达障碍物检测节点         -->
  <!-- 按距离过滤 ARS408 聚类目标  -->
  <!-- =========================== -->
  <node name="radar_only_obstacle" pkg="radar_obstacle"
        type="radar_only_obstacle.py" output="screen">

    <!-- 雷达点云话题（ARS408 已聚类） -->
    <param name="radar_topic" value="/radar/pointcloud" />

    <!-- 检测参数 -->
    <param name="target_distance"   value="1.3" />
    <param name="distance_tolerance" value="1.0" />
    <param name="max_angle_deg"     value="90.0" />

    <!-- 滤波参数 -->
    <param name="rcs_min"              value="-20.0" />
    <param name="persistence_frames"   value="3" />
    <param name="persistence_window"   value="5" />
    <param name="cluster_radius"       value="0.3" />

    <!-- 清除参数 -->
    <!-- clear_timeout: 障碍物消失后等待多久才清除 costmap（必须 > observation_persistence 0.5s） -->
    <!-- clear_cooldown: 两次清除之间的最小间隔，防止频繁重置 -->
    <param name="clear_timeout"  value="2.0" />
    <param name="clear_cooldown" value="1.0" />
  </node>

</launch>
